# ============================================================
# G&P Negocios Inmobiliarios — Variables de entorno
# Copiar en Vercel → Settings → Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Cloudinary (upload de fotos) ─────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Sitio ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gnp-inmobiliaria.vercel.app

# ── GOOGLE ANALYTICS 4 ──────────────────────────────────────
# Cómo obtener: analytics.google.com → Administrar → Propiedad → Streams de datos → Web
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── GOOGLE ADS ───────────────────────────────────────────────
# Cómo obtener: ads.google.com → Herramientas → Conversiones → ID de conversión
# Formato: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX

# Etiquetas de conversión individuales (en Google Ads → cada conversión tiene su label)
# Formato: XXXXXXXXXXX (la parte después del slash en AW-XXXXXXX/XXXXXXXXXXX)
NEXT_PUBLIC_GADS_CONV_LEAD=
NEXT_PUBLIC_GADS_CONV_FACTIBILIDAD=
NEXT_PUBLIC_GADS_CONV_WHATSAPP=

# ── META PIXEL (Facebook/Instagram) ──────────────────────────
# Cómo obtener: business.facebook.com → Administrador de eventos → Pixels → ID
# Formato: número de 15-16 dígitos
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# ── WhatsApp Business API (notificaciones de leads) ──────────
ADMIN_WHATSAPP_NOTIFY=5491112345678
WA_ACCESS_TOKEN=
WA_PHONE_ID=

# ── Cron job (seguimiento automático de leads) ───────────────
CRON_SECRET=genera-un-string-random-largo-aqui

# ── Claude API (generador de contenido RRSS) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...
